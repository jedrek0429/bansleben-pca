    "hague_purpose": {
      "title": "The purpose of this Convention is:",
      "items": [
        "to secure the prompt return of children wrongfully removed or retained in any signatory state;",
        "to effectively enforce in the other signatory states the rights of custody and visitation existing in a state that is signatory to the Convention."
      ],
      "citation": "Article 1 of the Hague Convention of 25 October 1980"
    }
