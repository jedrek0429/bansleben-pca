  "shared_blocks": {
    "un_crc_intro": {
      "text": "En vertu de la Convention des Nations Unies relative aux droits de l’enfant de 1989, entrée en vigueur en 1990, ce qui suit a été approuvé :"
    },
    "hague_purpose": {
      "title": "La présente Convention a pour objet :",
      "items": [
        "d’assurer le retour immédiat des enfants déplacés ou retenus illicitement dans tout État contractant ;",
        "de faire respecter effectivement dans les autres États contractants les droits de garde et de visite existant dans un État contractant."
      ],
      "citation": "Article premier de la Convention de La Haye du 25 octobre 1980"
    }
  },
